<?xml version="1.0"?>

<robot name="brov2heavy" xmlns:xacro="http://www.ros.org/wiki/xacro" >
  <xacro:arg name="debug" default="0"/>
  <xacro:arg name="robot_name" default="brov2heavy"/>
  <xacro:include filename="$(find brov2heavy_description)/urdf/brov2heavy.urdf.xacro"/>
  <xacro:brov2heavy robot_name="$(arg robot_name)" debug="$(arg debug)"/>
</robot>
