  </joint> 
  -->

  <joint name="rope_base_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.01545 0 0.31254"/>
    <parent link="base_link"/>
    <child link="rope_base_link"/>
  </joint>

</robot>
